# Ultimate SEO Content Machine — API Keys
# Copy this file to your project root as .env and fill in your values.
# Never commit .env to version control.

# Required
DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_PASSWORD=yourpassword
# Optional alternative to DATAFORSEO_LOGIN/DATAFORSEO_PASSWORD:
# base64(login:password)
DATAFORSEO_AUTH_BASE64=
ANTHROPIC_API_KEY=sk-ant-...

# Required for autonomous WordPress publishing
WP_BASE_URL=https://example.com
WP_USERNAME=wordpress-user
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Required for setup-complete analytics/refresher mode
GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/google-service-account.json
GA4_PROPERTY_ID=123456789
GSC_SITE_URL=sc-domain:example.com

# Worker/runtime
CONTENT_MACHINE_SITE_CONFIG=config/site.yaml
CONTENT_MACHINE_DATA_DIR=.content-machine
CONTENT_MACHINE_DB=.content-machine/content_machine.db
CONTENT_MACHINE_DRY_RUN=true
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional — improve /blog-write article quality
FIRECRAWL_API_KEY=           # better page scraping  (firecrawl.dev — free tier)
TAVILY_API_KEY=              # deeper topic research  (tavily.com — free tier)
YOUTUBE_API_KEY=             # video insights         (console.cloud.google.com)
GEMINI_API_KEY=              # Banana Claude/Gemini article images
BANANA_MODEL=gemini-3.1-flash-image-preview
BANANA_ASPECT_RATIO=16:9
BANANA_RESOLUTION=2K
